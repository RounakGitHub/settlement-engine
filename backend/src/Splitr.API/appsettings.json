{
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=splitr;Username=splitr;Password=splitr_dev",
    "Valkey": "localhost:6379"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "EnableIdempotence": true,
    "Topics": {
      "expense-events": ["ExpenseAdded", "ExpenseEdited", "ExpenseDeleted"],
      "settlement-events": ["SettlementProposed", "SettlementConfirmed", "SettlementExpired", "SettlementCancelled", "SettlementFailed"],
      "group-events": ["GroupCreated", "MemberJoined", "MemberLeft", "GroupArchived"],
      "debt-graph-events": ["DebtGraphUpdated"]
    },
    "Consumers": {
      "DebtSimplifierGroupId": "debt-simplifier",
      "SignalRDispatcherGroupId": "signalr-dispatcher",
      "EmailNotificationGroupId": "email-notifications"
    }
  },
  "Jwt": {
    "Issuer": "Splitr",
    "Audience": "Splitr",
    "ExpiryMinutes": 15
  },
  "Auth": {
    "BcryptCost": 12,
    "MaxFailedAttempts": 10,
    "LockoutMinutes": 30,
    "RefreshTokenExpiryDays": 30,
    "CookieName": "refreshToken",
    "CookiePath": "/api/auth"
  },
  "Group": {
    "MaxMembers": 50,
    "ArchiveRetentionDays": 90,
    "InviteCodeLength": 8
  },
  "Settlement": {
    "ExpiryHours": 24,
    "LockTimeoutSeconds": 30,
    "IdempotencyTtlHours": 24
  },
  "RateLimiting": {
    "AuthLogin": { "PermitLimit": 5, "WindowSeconds": 900, "SegmentsPerWindow": 5 },
    "AuthRegister": { "PermitLimit": 3, "WindowSeconds": 3600, "SegmentsPerWindow": 6 },
    "Write": { "PermitLimit": 30, "WindowSeconds": 60, "SegmentsPerWindow": 4 },
    "Settlement": { "PermitLimit": 10, "WindowSeconds": 60, "SegmentsPerWindow": 4 },
    "General": { "PermitLimit": 200, "WindowSeconds": 60, "SegmentsPerWindow": 4 }
  },
  "Razorpay": {
    "WebhookSecret": "CHANGE-THIS-IN-PRODUCTION",
    "AllowedIps": []
  },
  "Google": {
    "ClientId": "",
    "ClientSecret": ""
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000"]
  },
  "Smtp": {
    "Host": "localhost",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromAddress": "noreply@splitr.dev",
    "FromName": "Splitr",
    "EnableSsl": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  }
}
